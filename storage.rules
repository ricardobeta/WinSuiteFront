rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function esUsuarioDelTenant(tenantId) {
      return request.auth != null
        && request.auth.token.tenantId == tenantId;
    }

    // Archivos generales, XML, PDF, Excel e imágenes del negocio.
    // La aplicación también valida las extensiones permitidas; esta regla
    // impone el límite de tamaño en el perímetro de Firebase.
    match /archivos/{tenantId}/{allPaths=**} {
      allow read: if esUsuarioDelTenant(tenantId);

      allow write: if esUsuarioDelTenant(tenantId)
        && request.resource.size <= 2 * 1024 * 1024;

      allow delete: if esUsuarioDelTenant(tenantId);
    }

    // Certificados digitales: se gestionan únicamente desde WinServer
    // mediante Firebase Admin SDK, que no está sujeto a estas reglas.
    match /firmas/{tenantId}/{allPaths=**} {
      allow read, write, delete: if false;
    }

    // XML y RIDE generados por el backend.
    match /facturacion/{tenantId}/{allPaths=**} {
      allow read, write, delete: if false;
    }

    // Los assets de sitios viven en el proyecto Firebase Sites.
    // Todo path no declarado queda bloqueado por defecto.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
